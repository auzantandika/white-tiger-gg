# YouTube Data API v3 key (server-side only — cron scan job only)
YOUTUBE_API_KEY=your_youtube_data_api_v3_key

# Cron secret for /api/cron/scan-youtube-live (Bearer token or ?secret=)
CRON_SECRET=your_secret_here

# Live scan cache duration in seconds (default: 600 = 10 minutes)
YOUTUBE_LIVE_CACHE_SECONDS=600

# Number of streamers checked per rotating scan request (default: 20)
YOUTUBE_SCAN_BATCH_SIZE=20

# Optional legacy flag — uploads playlist detection is used by default
YOUTUBE_ENABLE_FALLBACK=false

# Quota budgeting (informational / future safeguards)
YOUTUBE_DAILY_QUOTA_BUDGET=8000
YOUTUBE_QUOTA_SAFETY_LIMIT=7500

# Persistent cache — Vercel KV or Upstash Redis REST (recommended for production)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
