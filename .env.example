# YouTube Data API v3 key (server-side only — never commit the real value)
YOUTUBE_API_KEY=your_youtube_data_api_v3_key

# Live scan cache duration in seconds (default: 300)
YOUTUBE_LIVE_CACHE_SECONDS=300

# Number of streamers checked per rotating scan request (default: 51)
YOUTUBE_SCAN_BATCH_SIZE=51

# Optional legacy flag — uploads playlist detection is used by default
YOUTUBE_ENABLE_FALLBACK=false
