PORT=4000
CACHE_SECONDS=600
CRON_SCHEDULE=*/10 * * * *

# Required for POST /scan-now (Authorization: Bearer <token> or ?token=)
LIVE_DATA_API_TOKEN=PASTE_RANDOM_TOKEN_HERE

# Required before enabling the real YouTube scanner
YOUTUBE_API_KEY=PASTE_YOUTUBE_API_KEY_HERE

# Uploads playlist fallback (default off — matches White Tiger GG production)
YOUTUBE_ENABLE_FALLBACK=false
